{
  "name": "infinityx-desktop",
  "version": "0.1.0",
  "description": "InfinityX Wallet desktop app.",
  "type": "module",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "desktop": "electron .",
    "exe:unpacked": "npm run build && electron-builder --win dir --x64",
    "exe": "npm run build && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.infinityx.wallet.desktop",
    "productName": "InfinityX Wallet",
    "executableName": "InfinityX Wallet",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  }
}
