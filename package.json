{
  "name": "infinityx-desktop",
  "version": "0.1.0",
  "description": "InfinityX Wallet desktop app.",
  "type": "module",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "desktop": "electron .",
    "backend:build": "python -m PyInstaller --onefile --clean --name infinityx_backend --distpath backend-dist --workpath backend-build --specpath backend-build backend/infinityx_backend.py",
    "exe:unpacked": "npm run build && npm run backend:build && electron-builder --win dir --x64",
    "exe": "npm run build && npm run backend:build && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.infinityx.wallet.desktop",
    "productName": "InfinityX Wallet",
    "executableName": "InfinityX Wallet",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-dist",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/data",
        "to": "backend/data",
        "filter": [
          "**/*.json"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@capacitor/core": "^8.3.4",
    "@cosmjs/amino": "^0.37.0",
    "@cosmjs/proto-signing": "^0.37.0",
    "@cosmjs/stargate": "^0.37.0",
    "@noble/hashes": "^2.2.0",
    "@reown/walletkit": "^1.5.5",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@walletconnect/core": "^2.23.9",
    "@walletconnect/utils": "^2.23.9",
    "bitcoinjs-lib": "^7.0.0",
    "buffer": "^6.0.3",
    "ecpair": "^3.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "viem": "^2.50.4",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "tronweb": "^6.3.0",
    "xrpl": "^4.6.0"
  }
}
